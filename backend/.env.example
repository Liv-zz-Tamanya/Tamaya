DATABASE_URL=postgresql+asyncpg://aidiary:aidiary@localhost:5432/aidiary
CLOVA_API_KEY=your-clova-api-key
# B-002: settings.py default와 동일한 OpenAI-호환 엔드포인트로 정정
CLOVA_BASE_URL=https://clovastudio.stream.ntruss.com/v1/openai
# B-003: settings.py default HCX-005로 통일
CLOVA_MODEL=HCX-005
# Agent Tool Calling: CLOVA Function Calling은 max token 1024 이상 권장
CLOVA_AGENT_MAX_TOKENS=1024
CLOVA_AGENT_TEMPERATURE=0.2
# CLOVA provider HTTP transport timeout (seconds)
CLOVA_AGENT_TIMEOUT_SECONDS=30
# PersonalAssistantAgent application deadlines (seconds): model call, one ToolNode round, full Graph
PERSONAL_ASSISTANT_MODEL_CALL_TIMEOUT_SECONDS=25
PERSONAL_ASSISTANT_TOOL_ROUND_TIMEOUT_SECONDS=15
PERSONAL_ASSISTANT_EXECUTION_TIMEOUT_SECONDS=45
# DEC-022.4: NCP API 키 수령 전 true. 수령 후 false로 변경
CLOVA_MOCK_MODE=true
# DEC-022.4: 카카오 REST API 앱 키 (https://developers.kakao.com 에서 발급)
KAKAO_APP_KEY=your-kakao-rest-api-key
# DEC-023: JWT 서명 시크릿 — 프로덕션에서는 openssl rand -hex 32 값으로 교체
JWT_SECRET=CHANGE_ME_IN_PRODUCTION_USE_STRONG_RANDOM_SECRET
