# Frontend 환경 변수 (Vite — VITE_ 접두사만 클라이언트에 노출)
# 복사: cp .env.example .env  (.env는 git-ignored)

# Backend(FastAPI) API base. 비우면 http://localhost:8000 사용.
VITE_API_BASE=http://localhost:8000

# AI 채팅을 backend(CLOVA, MOCK 가능)로 결선. false=로컬 시뮬레이션만.
VITE_AI_ENABLED=true

# (데모/개발 전용) 고정 device_id로 시드 데이터(웰빙 인사이트 등) 확인.
# production에서는 비워둘 것 — 비우면 정상 익명 device 발급.
# VITE_DEMO_DEVICE_ID=dev-demo-real
